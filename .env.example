# Application
APP_NAME=PetMedicationTracker
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://pet_app:WorkPasswordPet8353@db:5432/pet_medication_db
POSTGRES_USER=pet_app
POSTGRES_PASSWORD=WorkPasswordPet8353
POSTGRES_DB=pet_medication_db

# Redis
REDIS_URL=redis://redis:6379/0

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Password reset emails
# Base URL used to build the reset link sent by email, e.g. https://petmed.example.com
FRONTEND_URL=http://localhost:8000
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
# Leave SMTP_HOST empty to just log the reset link instead of sending a real email (local dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@petmed.local
SMTP_USE_TLS=true
